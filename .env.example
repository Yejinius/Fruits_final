# Young Fresh Mall 환경 설정 (.env 파일로 복사 후 값 입력)

# Aligo SMS
ALIGO_API_KEY=your_api_key
ALIGO_USER_ID=your_user_id
ALIGO_SENDER=010-0000-0000

# Admin 사이트
ADMIN_ID=your_admin_id
ADMIN_PW=your_admin_pw

# Flask
FLASK_SECRET_KEY=change-me-to-random-string
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# 쇼핑몰 URL (도메인 설정 후 변경)
SHOPPING_MALL_URL=http://localhost:5000

# 밴드 URL
BAND_PREVIEW_URL=
BAND_PRODUCTION_URL=
